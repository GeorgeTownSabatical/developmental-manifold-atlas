{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Organism and cohort context records",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "organism_id",
      "record_type",
      "species",
      "taxon_id",
      "breed_strain",
      "sex",
      "age_value",
      "age_unit",
      "developmental_stage",
      "body_mass",
      "body_mass_unit",
      "body_length",
      "body_length_unit",
      "reproductive_status",
      "generation",
      "environment",
      "geography",
      "ethics_status"
    ],
    "properties": {
      "organism_id": { "type": "string", "pattern": "^ORG-[A-Z0-9-]+$" },
      "record_type": { "enum": ["individual", "cohort", "aggregate", "synthetic"] },
      "species": { "type": "string" },
      "taxon_id": { "type": "string" },
      "breed_strain": { "type": "string" },
      "sex": { "enum": ["male", "female", "intersex", "mixed", "unknown", "not_applicable"] },
      "age_value": { "type": "number", "minimum": 0 },
      "age_unit": { "enum": ["days", "weeks", "months", "years", "gestational_weeks"] },
      "developmental_stage": { "enum": ["embryo", "fetus", "neonate", "infant", "juvenile", "pubertal", "adult", "aged"] },
      "body_mass": { "type": ["number", "string"], "minimum": 0 },
      "body_mass_unit": { "enum": ["g", "kg", "NA_NOT_MEASURED", "NA_NOT_REPORTED", "NA_NOT_APPLICABLE", "NA_RESTRICTED", "NA_UNKNOWN"] },
      "body_length": { "type": ["number", "string"], "minimum": 0 },
      "body_length_unit": { "enum": ["mm", "cm", "m", "NA_NOT_MEASURED", "NA_NOT_REPORTED", "NA_NOT_APPLICABLE", "NA_RESTRICTED", "NA_UNKNOWN"] },
      "reproductive_status": { "enum": ["prepubertal", "fertile", "subfertile", "infertile", "pregnant", "lactating", "unknown", "not_applicable"] },
      "generation": { "type": "string" },
      "environment": { "enum": ["lab", "wild", "farm", "clinic", "aggregate", "synthetic", "unknown"] },
      "geography": { "type": "string" },
      "ethics_status": { "type": "string" }
    }
  }
}

