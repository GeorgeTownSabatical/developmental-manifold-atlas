{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://developmental-manifold.org/schemas/dataset.schema.json",
  "title": "Dataset registry",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "dataset_id",
      "title",
      "version",
      "contributor",
      "description",
      "species",
      "population",
      "sex",
      "age_stage",
      "measurements",
      "sample_size",
      "data_level",
      "access_tier",
      "license",
      "ethics_status",
      "institution_id",
      "contact",
      "citation",
      "provenance",
      "limitations",
      "update_frequency",
      "quality_score"
    ],
    "properties": {
      "dataset_id": { "type": "string", "pattern": "^DS-[A-Z0-9-]+$" },
      "title": { "type": "string", "minLength": 3 },
      "version": { "type": "string" },
      "contributor": { "type": "string" },
      "description": { "type": "string", "minLength": 10 },
      "species": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
      "population": { "type": "string" },
      "sex": { "enum": ["male", "female", "mixed", "unknown"] },
      "age_stage": { "type": "string" },
      "measurements": { "type": "array", "items": { "type": "string" } },
      "sample_size": { "type": "integer", "minimum": 0 },
      "data_level": { "enum": ["individual", "cohort", "aggregate", "synthetic", "metadata-only"] },
      "access_tier": { "enum": ["synthetic", "public", "aggregate", "restricted", "metadata-only"] },
      "license": { "type": "string" },
      "ethics_status": { "type": "string" },
      "institution_id": { "type": "string" },
      "contact": { "type": "string" },
      "citation": { "type": "string" },
      "provenance": { "type": "string" },
      "limitations": { "type": "string" },
      "update_frequency": { "enum": ["static", "annual", "rolling", "unknown"] },
      "quality_score": { "type": "number", "minimum": 0, "maximum": 100 }
    }
  }
}
