{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Developmental State Objects",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": true,
    "required": ["dso_id", "dataset_id", "species", "sex", "age", "measurements", "provenance"],
    "properties": {
      "dso_id": { "type": "string", "pattern": "^DSO-[A-Z0-9-]+$" },
      "dataset_id": { "type": "string" },
      "species": { "type": "string" },
      "population": { "type": "string" },
      "sex": { "enum": ["male", "female", "unknown"] },
      "age": {
        "type": "object",
        "required": ["stage", "value", "unit"],
        "properties": {
          "stage": { "type": "string" },
          "value": { "type": "number", "minimum": 0 },
          "unit": { "type": "string" }
        }
      },
      "measurements": {
        "type": "object",
        "properties": {
          "agd_mm": { "type": "number", "minimum": 0 },
          "body_mass_g": { "type": "number", "minimum": 0 },
          "skull_length_mm": { "type": "number", "minimum": 0 },
          "snout_length_mm": { "type": "number", "minimum": 0 },
          "head_circumference_mm": { "type": "number", "minimum": 0 }
        }
      },
      "provenance": {
        "type": "object",
        "required": ["access_tier", "synthetic", "citation"],
        "properties": {
          "access_tier": { "enum": ["synthetic", "public", "aggregate", "restricted", "metadata-only"] },
          "synthetic": { "type": "boolean" },
          "citation": { "type": "string" }
        }
      }
    }
  }
}

